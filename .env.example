# ─────────────────────────────────────────────────────────────
# SpectrumForUs — Variables d'environnement
# Copier vers .env.local (dev) et configurer dans Vercel (prod).
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://aifuqpnqsqyugmxrjoqn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Supabase → Settings → API → anon/public

# ⚠️ CRITIQUE — secret, NE JAMAIS exposer côté client.
# Indispensable au webhook Stripe (création des commandes) et à la
# suppression de compte RGPD. Sans ça : paiement encaissé MAIS aucune
# commande créée (bloqué par la RLS).
# Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # Stripe → Developers → API keys → Publishable
STRIPE_SECRET_KEY=                      # Stripe → Developers → API keys → Secret

# ⚠️ CRITIQUE (sécurité) — sans ça le webhook accepte des events NON signés.
# Stripe → Developers → Webhooks → (endpoint /api/stripe/webhook) → Signing secret
STRIPE_WEBHOOK_SECRET=

# Prix de l'abonnement vendeur (9,90 €). Stripe → Products → Price ID (price_…)
NEXT_PUBLIC_STRIPE_VENDOR_PRICE_ID=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://spectrumforus.com

# ── Emails (Resend) ───────────────────────────────────────────
RESEND_API_KEY=                         # https://resend.com/api-keys

# ── Optionnels ────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
